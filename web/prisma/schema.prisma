generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  role         UserRole      @default(OWNER)
  fullName     String?
  draft        WillDraft?
  legacyVideos LegacyVideo[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model WillDraft {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  status    String   @default("DRAFT") // DRAFT | LOCKED
  step      Int      @default(1)
  data      Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegacyVideo {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName     String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  fileUrl      String?

  title        String?
  description  String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

enum UserRole {
  OWNER
  WITNESS
  ADMIN
}